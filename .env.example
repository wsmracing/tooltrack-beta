NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_YOUR_KEY
SUPABASE_SERVICE_ROLE_KEY=sb_secret_YOUR_SERVER_ONLY_KEY
NEXT_PUBLIC_APP_URL=https://tooltrack.ie
BETA_ACCESS_CODE=your-test-code

# Transactional email via Resend
RESEND_API_KEY=re_YOUR_KEY
RESEND_SIGHTING_FROM_EMAIL=sighting@mail.tooltrack.ie
RESEND_SHOP_FROM_EMAIL=shop@mail.tooltrack.ie
RESEND_SUPPORT_FROM_EMAIL=support@mail.tooltrack.ie
RESEND_REPLY_TO=support@tooltrack.ie
SHOP_ADMIN_EMAILS=support@tooltrack.ie

# Optional public support contact
NEXT_PUBLIC_SUPPORT_EMAIL=support@tooltrack.ie

# Optional internal signup notification recipient(s)
NEW_USER_NOTIFICATION_EMAILS=support@tooltrack.ie

# Optional logo test variants: wordmark, monogram, serial
NEXT_PUBLIC_LOGO_VARIANT=wordmark

# Private beta gate
BETA_COOKIE_MAX_AGE_HOURS=72
