NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_YOUR_KEY
SUPABASE_SERVICE_ROLE_KEY=sb_secret_YOUR_SERVER_ONLY_KEY
NEXT_PUBLIC_APP_URL=https://tooltrack-beta.vercel.app
BETA_ACCESS_CODE=your-test-code

# Sighting and test emails
RESEND_API_KEY=re_YOUR_KEY
# For real owner delivery, verify a domain in Resend and use it here.
RESEND_FROM_EMAIL=ToolTrack <alerts@your-verified-domain.ie>
# Prototype option: route every email to the email address linked to your Resend account.
# This lets you test with onboarding@resend.dev before buying/configuring a domain.
RESEND_TEST_RECIPIENT=your-resend-account-email@example.com

# Optional comma-separated list of shop administrator email addresses.
# These users can open /shop/admin during beta without a shop_admins database row.
SHOP_ADMIN_EMAILS=owner@example.com
